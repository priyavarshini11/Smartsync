# Port for the Express server to run on
PORT=5000

# Node environment (development or production)
NODE_ENV=production

# JWT Secret for authentication
JWT_SECRET=replace_me_with_a_strong_random_string

# VAPID keys for Web Push Notifications
# Generate a new set of keys using `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=replace_me_with_your_vapid_public_key
VAPID_PRIVATE_KEY=replace_me_with_your_vapid_private_key
