{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**",
      "maxDuration": 10
    }
  },
  "regions": ["bom1"],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/uploads/(.*)", "destination": "/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
